{
  "name": "unifi-protect-viewer",
  "version": "1.2.0",
  "description": "Unattended fullscreen UniFi Protect camera viewer for store and kiosk PCs.",
  "scripts": {
    "start": "tauri dev",
    "build": "tauri build",
    "test": "node scripts/run-tests.js",
    "test:coverage": "node scripts/run-tests.js --coverage",
    "format": "prettier --write \"src/**/*.{js,html,css}\"",
    "prepare": "node scripts/change-commit-hook-permissions.js && husky",
    "release": "node scripts/release.js"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "tauri",
    "unifi",
    "unifi-protect",
    "liveview",
    "camera",
    "surveillance",
    "fullscreen",
    "kiosk",
    "ubiquiti"
  ],
  "author": "Sebastian Loer",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@tauri-apps/cli": "2.11.4",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "prettier": "3.8.1"
  },
  "lint-staged": {
    "*.{js,html,css}": [
      "prettier --config .prettierrc.json --write"
    ]
  },
  "volta": {
    "node": "20.19.5"
  }
}
